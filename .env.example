# Copy this file to .env and fill in your values

# Gemini Vision API key (required for OCR extraction)
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# PostgreSQL connection string
DATABASE_URL=postgresql://quality_user:quality_pass@localhost:5432/stellantis_quality

# File storage paths (relative to backend directory)
UPLOAD_DIR=static/uploads
ROW_IMAGES_DIR=static/row_images

# Frontend API URL (used by Vite dev server)
VITE_API_URL=http://localhost:8000
